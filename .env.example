# Copy to .env. Used by both docker-compose.yml and the NestJS backend.

# Backend HTTP port
PORT=3001

# App metadata database (the advisor's own storage)
APP_DB_HOST=localhost
APP_DB_PORT=5433
APP_DB_USER=advisor
APP_DB_PASSWORD=advisor
APP_DB_NAME=advisor_meta

# Target database (the database we analyze; has pg_stat_statements)
TARGET_DB_HOST=localhost
TARGET_DB_PORT=5434
TARGET_DB_USER=target
TARGET_DB_PASSWORD=target
TARGET_DB_NAME=target_app
